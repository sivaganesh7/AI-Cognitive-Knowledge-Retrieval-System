# Server-only environment variables
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=second_brain_local

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

AUTH_MODE=local
DEV_LOCAL_UID=local-dev-user
DEV_LOCAL_EMAIL=local-dev@example.com
DEV_LOCAL_NAME=Local Developer

PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
API_RATE_LIMIT_MAX=5000
AI_RATE_LIMIT_MAX=600
REQUEST_TIMEOUT_MS=30000
MONGO_MAX_POOL_SIZE=60
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_CONNECTING=8
MONGO_WAIT_QUEUE_TIMEOUT_MS=10000
AI_MAX_CONCURRENT=8
AI_MAX_QUEUE=100
AUTO_PROCESS_NOTES_WITH_AI=false

ML_SERVICE_URL=http://127.0.0.1:8001
ML_REQUEST_TIMEOUT_MS=10000
